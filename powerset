//recursion 
#include <bits/stdc++.h>
using namespace std;
void powerset(int idx,vector<int>&v, vector<vector<int>> &pset,vector<int>&temp,int n){
    if(idx==n){
        pset.push_back(temp);
        return ;
    }
    temp.push_back(v[idx]);
    powerset(idx+1,v,pset,temp,n);
    temp.pop_back();
    powerset(idx+1,v,pset,temp,n);
    
}
int main() {
	// your code goes here
	vector<int>v={1,2,3};
    vector<vector<int>> pset;
    vector<int>temp;
    powerset(0,v,pset,temp,3);
	for(auto i:pset){
	    for(auto j:i){
	        cout<<j<<" ";
	    }cout<<endl;
	}
	cout<<0;
	return 0;
}
//bits
#include <bits/stdc++.h>
using namespace std;
vector<vector<int>>powerset(vector<int>&v,int n){
    vector<vector<int>>pset;
    for(int i=0;i<(1<<n);i++){
        vector<int>temp;
        for(int j=0;j<n;j++){
            if((i&(1<<j))!=0){
                temp.push_back(v[j]);/////
            }
        }
        pset.push_back(temp);
    }
    return pset;
}
int main() {
	// your code goes here
	vector<int>v={1,2,3};
    vector<vector<int>> pset=powerset(v,3);
	for(auto i:pset){
	    for(auto j:i){
	        cout<<j<<" ";
	    }cout<<endl;
	}
	return 0;
}
