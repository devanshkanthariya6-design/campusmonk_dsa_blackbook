#include <iostream>
#include <limits>
using namespace std;

int main() {
    int t;
    cin>>t;
    cin.ignore(numeric_limits<streamsize>::max(),'\n');
    while(t--){
        string s;
    getline(cin,s);///cin is wrong for empty strings
    if(s==""){
        cout<<"Invalid Input"<<endl;
        continue;
    }
    int hash[26]={0};
    for(auto c:s){
        hash[c-'a']+=1;
    }
    bool all_repeating=true;
    char firstrepeat='\0';
    char firstnonrepeat='\0';
    char mostrepeated=s[0];
    int maxfreq=hash[s[0]-'a'];
    for(auto c:s){/////////////////
        
        if(hash[c-'a']>1 && firstrepeat=='\0'){
            firstrepeat=c;
        }
        
        if(hash[c-'a']==1 && firstnonrepeat=='\0'){
            all_repeating=false;
            firstnonrepeat=c;
        }
        if(hash[c-'a']>maxfreq){
            mostrepeated=c;
            maxfreq=hash[c-'a'];
        }
    }
    if(all_repeating==false)cout<<firstnonrepeat<<endl;//////////
    cout<<mostrepeated<<endl;
    if(all_repeating==true){
        cout<<"None"<<firstrepeat<<endl;
    }
    }
    
    return 0;
}
