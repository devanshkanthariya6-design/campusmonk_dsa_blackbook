#include <bits/stdc++.h>
using namespace std;

int main() {
	// your code goes here
	vector<int>v;
	int num;
	unordered_map<int,int>mp;
	while(cin>>num){
	    v.push_back(num);
	    mp[num]++;
	}
	int minfreq=INT_MAX;//////////dont use 0(barna 0 se kam freq kbhi ayegi hi ni)
	int minfreqelement=v[0];
	int maxfreq=INT_MIN;/////////dont use 0
	int maxfreqelement=v[0];
	for(int i=0/*dont skip first element(update actual freq)*/;i<v.size();i++){
	    if(mp[v[i]]>maxfreq){
	        maxfreq=mp[v[i]];
	        maxfreqelement=v[i];
	    }
	    else if(mp[v[i]]<minfreq){
	        minfreq=mp[v[i]];
	        minfreqelement=v[i];
	    }
	}
	cout<<minfreqelement<<" "<<maxfreqelement;
	return 0;
}