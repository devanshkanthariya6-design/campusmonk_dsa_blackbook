#include <iostream>
#include <string>
using namespace std;

int main() {
	string s;
	getline(cin,s);
	string ans="";//////
	ans+=s[0];///////
	for(int i=1;i<s.size();i++){
	    if(s[i]!=ans.back()){
	        ans+=s[i];
	    }
	}
	cout<<ans<<endl;
	return 0;
}
//inplace
int main() {
	string s;
	getline(cin,s);
	for(int i=1;i<s.size();i++){
	    if(s[i]==s[i-1]){
	        s.erase(i,1);
	        i--;/////
	    }
	}
	cout<<s<<endl;
	return 0;
}
